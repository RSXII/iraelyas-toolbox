{
  "name": "iraelyas-toolbox",
  "version": "3.1.0",
  "description": "Iraelya's 5e Toolbox — Dungeon Master's Dashboard",
  "main": "electron/main.js",
  "author": {
    "name": "RSXII",
    "url": "https://github.com/RSXII"
  },
  "homepage": "https://github.com/RSXII/iraelyas-toolbox",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc && vite build",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --mac --win",
    "dist:mac:beta": "npm run build && electron-builder --mac --config electron-builder.beta.yml",
    "dist:win:beta": "npm run build && electron-builder --win --config electron-builder.beta.yml",
    "dist:all:beta": "npm run build && electron-builder --mac --win --config electron-builder.beta.yml",
    "typecheck": "tsc --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "svelte": "^5.55.8",
    "svelte-check": "^4.4.8",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.4",
    "wait-on": "^7.2.0"
  }
}
